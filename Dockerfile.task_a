#  Stage 1: Builder 
FROM python:3.11-slim AS builder

WORKDIR /build

RUN pip install --no-cache-dir --prefix=/install \
    anthropic \
    fastapi \
    "uvicorn[standard]" \
    pydantic

#  Stage 2: Runtime 
FROM python:3.11-slim AS runtime

WORKDIR /app

COPY --from=builder /install /usr/local

COPY core/__init__.py ./core/__init__.py
COPY core/user_profile.py ./core/user_profile.py
COPY tasks/__init__.py ./tasks/__init__.py
COPY tasks/task_a.py ./tasks/task_a.py
COPY tasks/frontend.py ./tasks/frontend.py
COPY tasks/frontend.html ./tasks/frontend.html

RUN useradd -m -u 1001 appuser
USER appuser

EXPOSE 8000

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"

CMD ["uvicorn", "tasks.task_a:create_app", "--factory", "--host", "0.0.0.0", "--port", "8000"]